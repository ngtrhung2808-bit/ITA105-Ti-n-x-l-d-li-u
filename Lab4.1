import pandas as pd
from sklearn.preprocessing import LabelEncoder
from sklearn.feature_extraction.text import TfidfVectorizer
from gensim.models import Word2Vec

le = LabelEncoder()

def clean_text(text):
    return str(text).lower().split()



#  BÀI 1: HOTEL REVIEW
# =========================================================
print("\n===== BÀI 1: HOTEL REVIEW =====")

df1 = pd.read_csv("lab4/ITA105_Lab_4_Hotel_reviews.csv", quotechar='"')

print("\n5 dòng đầu:")
print(df1.head())

print("\nMissing values:")
print(df1.isnull().sum())

# xử lý missing
df1["review_text"] = df1["review_text"].fillna("")
df1["hotel_name"] = df1["hotel_name"].fillna("Unknown")
df1["customer_type"] = df1["customer_type"].fillna("Unknown")

# encoding
df1["hotel_encoded"] = le.fit_transform(df1["hotel_name"])
df1 = pd.get_dummies(df1, columns=["customer_type"])

print("\nSau encoding:")
print(df1.head())

# text processing
df1["tokens"] = df1["review_text"].apply(clean_text)
df1["clean_text"] = df1["tokens"].apply(lambda x: " ".join(x))

# TF-IDF
tfidf1 = TfidfVectorizer(max_features=100)
tfidf_matrix1 = tfidf1.fit_transform(df1["clean_text"])

print("\nTF-IDF shape:", tfidf_matrix1.shape)

# Word2Vec
model1 = Word2Vec(df1["tokens"], vector_size=100, window=3, min_count=1)

print("\nTừ gần 'sạch sẽ':")
print(model1.wv.most_similar("sạch sẽ") if "sạch sẽ" in model1.wv else "Không có")


