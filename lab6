def add_gaussian_noise(img):
    noise = np.random.normal(0, 25, img.shape)
    noisy = np.clip(img + noise, 0, 255).astype(np.uint8)
    return noisy

def preprocess_vehicle(img_path):
    img = cv2.imread(img_path)
    if img is None:
        print(f"Error: Image not found at {img_path}")
        return []
    img = cv2.resize(img, (224,224))

    # Noise
    noise = add_gaussian_noise(img)

    # Brightness ±15%
    factor = 1 + random.uniform(-0.15, 0.15)
    bright = np.clip(img * factor, 0, 255).astype(np.uint8)

    # Rotate ±10°
    angle = random.choice([-10, 10])
    M = cv2.getRotationMatrix2D((112,112), angle, 1)
    rotate = cv2.warpAffine(img, M, (224,224))

    # (Optional) grayscale
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    # Normalize
    gray = gray / 255.0

    return [noise, bright, rotate, gray]

