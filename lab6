def random_crop(img):
    h, w = img.shape[:2]
    start_x = random.randint(0, w//4)
    start_y = random.randint(0, h//4)
    crop = img[start_y:start_y+150, start_x:start_x+150]
    return cv2.resize(crop, (224,224))

def zoom(img):
    return cv2.resize(img[30:190, 30:190], (224,224))

def preprocess_fruit(img_path):
    img = cv2.imread(img_path)
    if img is None:
        print(f"Error: Image not found at {img_path}")
        return []
    img = cv2.resize(img, (224,224))

    flip = cv2.flip(img, 1)
    crop = random_crop(img)
    zoomed = zoom(img)

    angle = random.randint(-15,15)
    M = cv2.getRotationMatrix2D((112,112), angle, 1)
    rotate = cv2.warpAffine(img, M, (224,224))

    images = [flip, crop, zoomed, rotate]

    # Normalize
    images = [im/255.0 for im in images]

    return images

