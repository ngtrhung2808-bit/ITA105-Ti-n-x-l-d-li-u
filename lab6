def preprocess_room(img_path):
    img = cv2.imread(img_path)
    if img is None:
        print(f"Error: Image not found at {img_path}")
        return None, []
    img = cv2.resize(img, (224,224))

    original = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    # Flip
    flip = cv2.flip(img, 1)

    # Rotate
    angle = random.choice([-15,15])
    M = cv2.getRotationMatrix2D((112,112), angle, 1)
    rotate = cv2.warpAffine(img, M, (224,224))

    # Brightness
    factor = 1 + random.uniform(-0.2, 0.2)
    bright = np.clip(img * factor, 0, 255).astype(np.uint8)

    aug = [flip, rotate, bright]

    # Grayscale + normalize
    aug_processed = []
    for im in aug:
        gray = cv2.cvtColor(im, cv2.COLOR_BGR2GRAY)
        norm = gray / 255.0
        aug_processed.append(norm)

    return original, aug_processed

